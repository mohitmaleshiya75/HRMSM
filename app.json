{
  "expo": {
    "name": "HRMSM",
    "slug": "HRMSM",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/hrmsmlogo.png",
    "scheme": "hrmsm",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/hrmsmlogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.hrmsm.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/hrmsmlogo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/hrmsmlogo.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "unstable_useServerMiddleware": true
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "unstable_useServerMiddleware": true
      },
      "eas": {
        "projectId": "bf36ef80-b827-421a-bee4-e9071b8a039a"
      }
    },
    "owner": "hrmsm1"
  }
}
